pkgname=open-design
pkgver=0.3.0
pkgrel=1
_tag="open-design-v${pkgver}"
pkgdesc="Open Design desktop app"
arch=("x86_64")
url="https://github.com/nexu-io/open-design"
license=("Apache-2.0")
depends=(
  "gtk3"
  "nss"
  "alsa-lib"
  "libxss"
)
makedepends=(
  "git"
  "nodejs"
  "pnpm"
  "python"
  "make"
  "gcc"
)
source=(
  "${pkgname}-${pkgver}.tar.gz::https://github.com/nexu-io/open-design/archive/refs/tags/${_tag}.tar.gz"
)
sha256sums=(
  "SKIP"
)

build() {
  cd "open-design-${_tag}"

  export PNPM_HOME="$srcdir/pnpm-home"
  export PATH="$PNPM_HOME:$PATH"
  export CI=true

  pnpm install --frozen-lockfile
  pnpm tools-pack linux build --to dir
}

package() {
  cd "open-design-${_tag}"

  install -dm755 "$pkgdir/opt/open-design"

  echo "Searching for Linux build output..."
  find . -maxdepth 6 -type d \( -name "linux-unpacked" -o -name "*linux*" -o -name "*unpacked*" \)

  if [ -d "dist/linux-unpacked" ]; then
    cp -a dist/linux-unpacked/. "$pkgdir/opt/open-design/"
  elif [ -d "apps/desktop/dist/linux-unpacked" ]; then
    cp -a apps/desktop/dist/linux-unpacked/. "$pkgdir/opt/open-design/"
  elif [ -d "apps/desktop/release/linux-unpacked" ]; then
    cp -a apps/desktop/release/linux-unpacked/. "$pkgdir/opt/open-design/"
  else
    echo "Could not find Linux unpacked build output."
    exit 1
  fi

  install -dm755 "$pkgdir/usr/bin"

  if [ -x "$pkgdir/opt/open-design/open-design" ]; then
    ln -s /opt/open-design/open-design "$pkgdir/usr/bin/open-design"
  elif [ -x "$pkgdir/opt/open-design/Open Design" ]; then
    ln -s "/opt/open-design/Open Design" "$pkgdir/usr/bin/open-design"
  else
    echo "Could not find Open Design executable."
    find "$pkgdir/opt/open-design" -maxdepth 2 -type f -executable
    exit 1
  fi

  install -dm755 "$pkgdir/usr/share/applications"
  cat > "$pkgdir/usr/share/applications/open-design.desktop" <<EOF
[Desktop Entry]
Name=Open Design
Comment=Open Design desktop app
Exec=/usr/bin/open-design
Icon=open-design
Terminal=false
Type=Application
Categories=Graphics;Development;
EOF
}