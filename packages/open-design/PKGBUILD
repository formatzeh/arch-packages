pkgname=open-design
pkgver=0.3.0
pkgrel=2
_tag="open-design-v${pkgver}"
pkgdesc="Open Design desktop app"
arch=("x86_64")
url="https://github.com/nexu-io/open-design"
license=("Apache-2.0")
depends=(
  "gtk3"
  "nss"
  "alsa-lib"
  "libxss"
)
makedepends=(
  "git"
  "nodejs"
  "pnpm"
  "python"
  "make"
  "gcc"
)
source=(
  "${pkgname}-${pkgver}.tar.gz::https://github.com/nexu-io/open-design/archive/refs/tags/${_tag}.tar.gz"
)
sha256sums=(
  "SKIP"
)

build() {
  cd "open-design-${_tag}"

  export PNPM_HOME="$srcdir/pnpm-home"
  export PATH="$PNPM_HOME:$PATH"
  export CI=true

  pnpm install --frozen-lockfile

  echo "Running Open Design Linux packer..."
  pnpm tools-pack linux build --to dir --dir "$srcdir/tools-pack" --json | tee "$srcdir/tools-pack-result.json"

  echo "tools-pack result:"
  cat "$srcdir/tools-pack-result.json"

  echo "Searching for generated Linux output inside srcdir..."
  find "$srcdir" -maxdepth 8 \( \
    -name "linux-unpacked" -o \
    -name "Open Design" -o \
    -name "*.AppImage" -o \
    -name "builder" -o \
    -name "Open-Design*" \
  \) -print || true
}

package() {
  cd "open-design-${_tag}"

  install -dm755 "$pkgdir/opt/open-design"

  echo "Inspecting tools-pack result..."
  cat "$srcdir/tools-pack-result.json" || true

  echo "Searching for usable Open Design build output..."
  find "$srcdir" -maxdepth 10 \( \
    -name "linux-unpacked" -o \
    -name "Open Design" -o \
    -name "*.AppImage" -o \
    -name "Open-Design*" \
  \) -print || true

  build_output="$(find "$srcdir" -type d -name "linux-unpacked" | head -n 1)"

  if [ -z "$build_output" ]; then
    echo "Could not find linux-unpacked directory."
    echo "Full tools-pack tree:"
    find "$srcdir" -maxdepth 6 -type d -print || true
    exit 1
  fi

  echo "Using build output: $build_output"
  cp -a "$build_output/." "$pkgdir/opt/open-design/"

  install -dm755 "$pkgdir/usr/bin"

  executable="$(find "$pkgdir/opt/open-design" -maxdepth 2 -type f -executable \( -name "Open Design" -o -name "open-design" \) | head -n 1)"

  if [ -z "$executable" ]; then
    echo "Could not find Open Design executable."
    find "$pkgdir/opt/open-design" -maxdepth 3 -type f -executable -print
    exit 1
  fi

  ln -s "${executable#$pkgdir}" "$pkgdir/usr/bin/open-design"

  install -dm755 "$pkgdir/usr/share/applications"
  cat > "$pkgdir/usr/share/applications/open-design.desktop" <<EOF
[Desktop Entry]
Name=Open Design
Comment=Open Design desktop app
Exec=/usr/bin/open-design
Icon=open-design
Terminal=false
Type=Application
Categories=Graphics;Development;
EOF
}