pkgname=dredge-tui-git
_pkgname=dredge
pkgver=0.1.0.r0.g0000000
pkgrel=1
pkgdesc="Terminal-first encrypted vault: search notes, configs, keys, and secrets in milliseconds"
arch=("x86_64")
options=(!strip !debug)
url="https://github.com/formatzeh/dredge_tui"
license=("MIT")
depends=(
  "glibc"
)
makedepends=(
  "base-devel"
  "git"
  "go"
)
optdepends=(
  "git: sync your vault with a remote repository"
  "github-cli: authenticate to GitHub without configuring git credentials"
)
provides=("dredge")
conflicts=("dredge")
source=(
  # The leading "<name>::" forces the extracted dir to be src/dredge/,
  # which matches $_pkgname. Without it, the dir would be src/dredge_tui/.
  "$_pkgname::git+https://github.com/formatzeh/dredge_tui.git#branch=main"
)
sha256sums=(
  "SKIP"
)

pkgver() {
  cd "$srcdir/$_pkgname"

  # No tagged version in this fork yet; lock the base at 0.1.0 and append git info.
  local rev
  rev="$(git rev-list --count HEAD)"

  local commit
  commit="$(git rev-parse --short HEAD)"

  printf "0.1.0.r%s.g%s" "$rev" "$commit"
}

build() {
  cd "$srcdir/$_pkgname"

  export CGO_CPPFLAGS="${CPPFLAGS}"
  export CGO_CFLAGS="${CFLAGS}"
  export CGO_CXXFLAGS="${CXXFLAGS}"
  export CGO_LDFLAGS="${LDFLAGS}"
  export GOFLAGS="-buildmode=pie -trimpath -ldflags=-linkmode=external -ldflags=-s -ldflags=-w -mod=readonly -modcacherw"

  go build -o "$_pkgname" ./cmd/"$_pkgname"
}

check() {
  cd "$srcdir/$_pkgname"

  # internal/crypto tests call CacheKey() which uses $XDG_RUNTIME_DIR if set,
  # otherwise falls back to /run/user/$UID. In the CI container (no systemd-logind)
  # the fallback path doesn't exist and the tests fail with permission errors.
  # Provide a writable temp runtime dir so the tests exercise the real code path.
  export XDG_RUNTIME_DIR="$srcdir/runtime"
  mkdir -p "$XDG_RUNTIME_DIR"
  chmod 700 "$XDG_RUNTIME_DIR"

  go test -short ./...
}

package() {
  cd "$srcdir/$_pkgname"

  install -Dm755 "$_pkgname" "$pkgdir/usr/bin/$_pkgname"

  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
